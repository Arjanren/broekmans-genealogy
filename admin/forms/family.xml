<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="basic">
        <field name="id" type="hidden" />
        <field name="husband_id" type="hidden" />
        <field name="wife_id" type="hidden" />
        <field name="marriage_date" type="calendar" label="Trouwdatum" format="%d-%m-%Y" />
        <field name="marriage_place" type="text" label="Trouwplaats" />
        <field name="divorce_date" type="calendar" label="Scheidingsdatum" format="%d-%m-%Y" />
        <field name="wedding_card_front" type="media" label="Trouwkaart - voorkant" preview="true" />
        <field name="wedding_card_inside_left" type="media" label="Trouwkaart - binnenkant links" preview="true" />
        <field name="wedding_card_inside_right" type="media" label="Trouwkaart - binnenkant rechts" preview="true" />
        <field name="wedding_card_back" type="media" label="Trouwkaart - achterkant" preview="true" />
        <field name="marriage_certificate_front" type="media" label="Trouwakte - pagina 1 / voorkant" preview="true" />
        <field name="marriage_certificate_page_2" type="media" label="Trouwakte - pagina 2" preview="true" />
        <field name="marriage_certificate_page_3" type="media" label="Trouwakte - pagina 3" preview="true" />
        <field name="marriage_certificate_back" type="media" label="Trouwakte - pagina 4 / achterkant" preview="true" />
        <field name="notes" type="editor" label="Notities" buttons="true" hide="pagebreak,readmore" />
        <field name="children_ids" type="hidden" multiple="true" />
    </fieldset>
</form>
